<UserControl x:Class="CandyHandyman.Desktop.HelpManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="帮助管理" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

        <DataGrid Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="标题" Binding="{Binding Title}" Width="200"/>
                <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="100"/>
                <DataGridTextColumn Header="排序" Binding="{Binding SortOrder}" Width="60"/>
                <DataGridTextColumn Header="浏览量" Binding="{Binding ViewCount}" Width="60"/>
                <DataGridTextColumn Header="状态" Binding="{Binding IsActive}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
