<UserControl x:Class="CandyHandyman.Desktop.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="用户管理" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="刷新" Click="Refresh_Click" Padding="16,6" Background="#FF6B35" Foreground="White" BorderThickness="0"/>
        </StackPanel>

        <DataGrid Grid.Row="2" x:Name="UsersGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" AlternatingRowBackground="#FAFAFA">
            <DataGrid.Columns>
                <DataGridTextColumn Header="昵称" Binding="{Binding Nickname}" Width="120"/>
                <DataGridTextColumn Header="手机号" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="角色" Binding="{Binding Role}" Width="80"/>
                <DataGridTextColumn Header="余额" Binding="{Binding Balance}" Width="100"/>
                <DataGridTextColumn Header="注册时间" Binding="{Binding CreatedAt}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>