<UserControl x:Class="CandyHandyman.Desktop.ReviewManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="评价管理" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

        <DataGrid Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="评价者" Binding="{Binding Customer.Nickname}" Width="120"/>
                <DataGridTextColumn Header="被评工匠" Binding="{Binding Provider.Nickname}" Width="120"/>
                <DataGridTextColumn Header="评分" Binding="{Binding Rating}" Width="80"/>
                <DataGridTextColumn Header="评价内容" Binding="{Binding Content}" Width="300"/>
                <DataGridTextColumn Header="时间" Binding="{Binding CreatedAt}" Width="160"/>
                <DataGridTemplateColumn Header="操作" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="删除" Padding="8,2" Foreground="Red"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>