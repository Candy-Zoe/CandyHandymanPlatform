<UserControl x:Class="CandyHandyman.Desktop.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="管理仪表盘" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

        <WrapPanel Grid.Row="1">
            <Border Background="White" CornerRadius="8" Padding="24" Margin="0,0,16,16" Width="240" Height="120">
                <StackPanel>
                    <TextBlock Text="总用户数" FontSize="14" Foreground="Gray"/>
                    <TextBlock x:Name="UserCount" Text="--" FontSize="32" FontWeight="Bold" Foreground="#FF6B35"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="8" Padding="24" Margin="0,0,16,16" Width="240" Height="120">
                <StackPanel>
                    <TextBlock Text="总订单数" FontSize="14" Foreground="Gray"/>
                    <TextBlock x:Name="OrderCount" Text="--" FontSize="32" FontWeight="Bold" Foreground="#03DAC6"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="8" Padding="24" Margin="0,0,16,16" Width="240" Height="120">
                <StackPanel>
                    <TextBlock Text="总服务数" FontSize="14" Foreground="Gray"/>
                    <TextBlock x:Name="ServiceCount" Text="--" FontSize="32" FontWeight="Bold" Foreground="#4CAF50"/>
                </StackPanel>
            </Border>
            <Border Background="White" CornerRadius="8" Padding="24" Margin="0,0,16,16" Width="240" Height="120">
                <StackPanel>
                    <TextBlock Text="系统状态" FontSize="14" Foreground="Gray"/>
                    <TextBlock Text="运行中" FontSize="32" FontWeight="Bold" Foreground="#4CAF50"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <TextBlock Grid.Row="2" Text="选择左侧菜单进行管理" FontSize="16" Foreground="Gray"
                   VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,0"/>
    </Grid>
</UserControl>