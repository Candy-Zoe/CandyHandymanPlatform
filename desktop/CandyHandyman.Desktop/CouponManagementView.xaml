<UserControl x:Class="CandyHandyman.Desktop.CouponManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="优惠券管理" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

        <DataGrid Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" x:Name="CouponGrid">
            <DataGrid.Columns>
                <DataGridTextColumn Header="优惠码" Binding="{Binding Code}" Width="120"/>
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="160"/>
                <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="80"/>
                <DataGridTextColumn Header="折扣值" Binding="{Binding DiscountValue}" Width="80"/>
                <DataGridTextColumn Header="最低金额" Binding="{Binding MinAmount}" Width="80"/>
                <DataGridTextColumn Header="最大使用" Binding="{Binding MaxUses}" Width="80"/>
                <DataGridTextColumn Header="已使用" Binding="{Binding UsedCount}" Width="60"/>
                <DataGridTextColumn Header="过期时间" Binding="{Binding ExpiresAt}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
