<UserControl x:Class="CandyHandyman.Desktop.OrderManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="订单管理" FontSize="24" FontWeight="Bold"/>
            <Button Content="刷新" Click="Refresh_Click" Padding="16,6" Margin="16,0,0,0" Background="#FF6B35" Foreground="White" BorderThickness="0"/>
        </StackPanel>

        <DataGrid Grid.Row="1" x:Name="OrdersGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" AlternatingRowBackground="#FAFAFA">
            <DataGrid.Columns>
                <DataGridTextColumn Header="订单号" Binding="{Binding OrderNo}" Width="180"/>
                <DataGridTextColumn Header="金额" Binding="{Binding TotalAmount}" Width="100"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                <DataGridTextColumn Header="地址" Binding="{Binding Address}" Width="200"/>
                <DataGridTextColumn Header="下单时间" Binding="{Binding CreatedAt}" Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>