.card { background: white; padding: 32rpx; border-radius: 16rpx; margin-top: 32rpx; text-align: center; }
.success-icon { font-size: 80rpx; color: #4CAF50; display: block; }
.success-text { font-size: 36rpx; font-weight: bold; color: #4CAF50; display: block; margin: 16rpx 0; }
.pending-icon { font-size: 80rpx; display: block; }
.pending-text { font-size: 36rpx; font-weight: bold; display: block; margin: 16rpx 0; }
.info-text { font-size: 26rpx; color: #999; display: block; }
.form-title { font-size: 32rpx; font-weight: bold; text-align: left; margin-bottom: 24rpx; display: block; }
.form-input { border-bottom: 2rpx solid #F0F0F0; padding: 20rpx 0; margin-bottom: 20rpx; font-size: 28rpx; }
.upload-btn { background: #F5F5F5; color: #666; margin-bottom: 16rpx; border-radius: 12rpx; }