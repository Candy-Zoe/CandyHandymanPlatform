.tabs { display: flex; background: white; margin-bottom: 16rpx; }
.tab { flex: 1; text-align: center; padding: 20rpx; font-size: 28rpx; color: #666; }
.tab.active { color: #FF6B35; border-bottom: 4rpx solid #FF6B35; font-weight: bold; }
.order-card { background: white; padding: 24rpx; border-radius: 16rpx; margin-bottom: 16rpx; }
.order-no { font-size: 26rpx; color: #999; }
.order-status { font-size: 26rpx; color: #FF6B35; }
.order-amount { font-size: 32rpx; font-weight: bold; color: #FF6B35; display: block; margin: 12rpx 0; }
.order-address { font-size: 24rpx; color: #999; }