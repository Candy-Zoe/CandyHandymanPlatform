.service-swiper { height: 500rpx; }
.swiper-image { width: 100%; height: 100%; }
.info-card { background: white; padding: 24rpx; margin: 16rpx 0; border-radius: 16rpx; }
.service-title { font-size: 34rpx; font-weight: bold; display: block; margin-bottom: 12rpx; }
.service-price { color: #FF6B35; font-size: 36rpx; font-weight: bold; display: block; }
.handyman-avatar { width: 80rpx; height: 80rpx; border-radius: 50%; margin-right: 16rpx; }
.handyman-name { font-size: 28rpx; font-weight: bold; display: block; }
.handyman-exp { font-size: 24rpx; color: #999; }
.section-title { font-size: 28rpx; font-weight: bold; margin-bottom: 12rpx; display: block; }
.service-desc { font-size: 26rpx; color: #666; line-height: 40rpx; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; padding: 16rpx 24rpx; background: white; box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05); }
.btn-chat { flex: 1; height: 80rpx; line-height: 80rpx; text-align: center; border: 2rpx solid #FF6B35; color: #FF6B35; border-radius: 12rpx; margin-right: 16rpx; }
.btn-order { flex: 2; height: 80rpx; line-height: 80rpx; text-align: center; background: #FF6B35; color: white; border-radius: 12rpx; }