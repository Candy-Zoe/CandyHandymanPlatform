.container {
  padding: 20rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

.header {
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.date-list {
  white-space: nowrap;
  margin-bottom: 30rpx;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  margin-right: 16rpx;
  background-color: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
}

.date-item.selected {
  border-color: #FF6B35;
  background-color: #FFF5F0;
}

.date-month {
  font-size: 28rpx;
  color: #333;
}

.date-weekday {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.slot-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.slot-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
}

.slot-time {
  flex: 1;
}

.time-text {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
}

.select-btn {
  background-color: #FF6B35;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.empty {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  color: #999;
  font-size: 30rpx;
}
