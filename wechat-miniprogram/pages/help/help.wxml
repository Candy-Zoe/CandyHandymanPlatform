<view class="container">
  <view wx:if="{{!selectedTopic}}">
    <view class="header"><text class="title">帮助中心</text></view>
    <view class="list">
      <view class="item" wx:for="{{topics}}" wx:key="id" bindtap="selectTopic" data-id="{{item.id}}">
        <text class="item-title">{{item.title}}</text>
        <text class="item-category">{{item.category}}</text>
      </view>
    </view>
  </view>
  <view wx:else>
    <view class="detail-header">
      <text class="back-btn" bindtap="goBack">← 返回</text>
      <text class="detail-title">{{selectedTopic.title}}</text>
    </view>
    <view class="detail-content">
      <rich-text nodes="{{selectedTopic.content}}"></rich-text>
    </view>
  </view>
</view>
