.profile-header { background: #FF6B35; padding: 48rpx 24rpx; display: flex; align-items: center; }
.avatar { width: 120rpx; height: 120rpx; border-radius: 50%; margin-right: 24rpx; border: 4rpx solid white; }
.nickname { font-size: 34rpx; font-weight: bold; color: white; display: block; }
.phone { font-size: 26rpx; color: rgba(255,255,255,0.8); }
.menu-list { background: white; border-radius: 16rpx; margin-top: 24rpx; overflow: hidden; }
.menu-item { padding: 28rpx 24rpx; border-bottom: 1rpx solid #F0F0F0; font-size: 30rpx; }
.menu-item:last-child { border-bottom: none; }