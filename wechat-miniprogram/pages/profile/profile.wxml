<view class="container">
  <view class="profile-header">
    <view class="avatar-circle">
      <text class="avatar-text">{{userInfo.nickname ? userInfo.nickname[0] : '?'}}</text>
    </view>
    <view class="user-info">
      <text class="nickname">{{userInfo.nickname || '未登录'}}</text>
      <text class="phone">{{userInfo.phone || ''}}</text>
      <text class="balance">余额: ¥{{userInfo.balance || 0}}</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goNotifications">消息通知</view>
    <view class="menu-item" bindtap="goNearby">附近工匠</view>
    <view class="menu-item" bindtap="goVerification">实名认证</view>
    <view class="menu-item" bindtap="goCertification">技能认证</view>
    <view class="menu-item" bindtap="goProvider">工匠中心</view>
    <view class="menu-item" bindtap="goPublish">发布服务</view>
    <view class="menu-item" bindtap="goOrders">我的订单</view>
    <view class="menu-item" bindtap="goWallet">我的钱包</view>
    <view class="menu-item" bindtap="goCoupons">优惠券</view>
    <view class="menu-item" bindtap="goFavorites">我的收藏</view>
    <view class="menu-item" bindtap="goHistory">浏览历史</view>
    <view class="menu-item" bindtap="goPayment">支付记录</view>
    <view class="menu-item" bindtap="goDisputes">纠纷仲裁</view>
    <view class="menu-item" bindtap="goAnnouncements">平台公告</view>
    <view class="menu-item" bindtap="goHelp">帮助中心</view>
    <view class="menu-item" bindtap="goFeedback">意见反馈</view>
  </view>
</view>