.search-bar {
  display: flex;
  align-items: center;
  background: white;
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  margin-bottom: 24rpx;
}

.search-placeholder {
  color: #999;
  margin-left: 12rpx;
  font-size: 28rpx;
}

.quick-entry {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.entry-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: white;
  border-radius: 12rpx;
  padding: 20rpx;
}

.entry-icon {
  font-size: 40rpx;
  margin-right: 8rpx;
}

.entry-text {
  font-size: 28rpx;
  color: #333;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 24rpx;
  color: #333;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.service-card {
  background: white;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.service-image {
  width: 100%;
  height: 320rpx;
}

.service-info {
  padding: 20rpx;
}

.service-title {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.service-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.service-price {
  color: #FF6B35;
  font-size: 32rpx;
  font-weight: bold;
}

.service-rating {
  color: #FFC107;
  font-size: 26rpx;
}