.container {
  padding: 20rpx;
  background-color: #F5F5F5;
  min-height: 100vh;
}

.header {
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.coupon-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.coupon-item {
  display: flex;
  background-color: #fff;
  border-radius: 12rpx;
  overflow: hidden;
}

.coupon-item.used {
  opacity: 0.6;
}

.coupon-left {
  width: 180rpx;
  background: linear-gradient(135deg, #FF6B35, #FF8F65);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
}

.coupon-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.coupon-condition {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.coupon-right {
  flex: 1;
  padding: 20rpx;
}

.coupon-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.coupon-code {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 8rpx;
}

.coupon-expire {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}

.coupon-used {
  font-size: 22rpx;
  color: #FF4D4F;
  display: block;
  margin-top: 8rpx;
}

.empty {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 400rpx;
  color: #999;
  font-size: 30rpx;
}
