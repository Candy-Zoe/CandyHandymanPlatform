<view class="container">
  <view class="header"><text class="title">我的收藏</text></view>
  <view class="list" wx:if="{{favorites.length > 0}}">
    <view class="item" wx:for="{{favorites}}" wx:key="id" bindtap="goDetail" data-service-id="{{item.serviceId}}" data-handyman-id="{{item.handymanProfileId}}">
      <view class="info">
        <text class="name">{{item.serviceTitle || item.handymanName || '未知'}}</text>
        <text class="time">{{item.createdAt}}</text>
      </view>
      <text class="remove" catchtap="removeFavorite" data-service-id="{{item.serviceId}}" data-handyman-id="{{item.handymanProfileId}}">取消收藏</text>
    </view>
  </view>
  <view class="empty" wx:else><text>暂无收藏</text></view>
</view>
