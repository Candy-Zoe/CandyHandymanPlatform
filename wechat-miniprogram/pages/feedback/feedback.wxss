.container{padding:20rpx;background:#F5F5F5;min-height:100vh}
.header{padding:20rpx 0;margin-bottom:20rpx}
.title{font-size:36rpx;font-weight:bold;color:#333}
.form{background:#fff;border-radius:12rpx;padding:24rpx;margin-bottom:30rpx}
.picker{padding:20rpx;background:#F5F5F5;border-radius:8rpx;margin-bottom:16rpx;font-size:28rpx;color:#333}
.textarea{width:100%;height:200rpx;background:#F5F5F5;border-radius:8rpx;padding:16rpx;font-size:28rpx;box-sizing:border-box;margin-bottom:16rpx}
.input{width:100%;height:80rpx;background:#F5F5F5;border-radius:8rpx;padding:0 16rpx;font-size:28rpx;box-sizing:border-box;margin-bottom:16rpx}
.submit-btn{background:#FF6B35;color:#fff;border-radius:8rpx;font-size:30rpx}
.section-title{font-size:32rpx;font-weight:bold;color:#333;margin-bottom:16rpx}
.list{display:flex;flex-direction:column;gap:16rpx}
.item{background:#fff;border-radius:12rpx;padding:24rpx}
.item-header{display:flex;justify-content:space-between;margin-bottom:8rpx}
.item-type{font-size:26rpx;color:#FF6B35;background:#FFF5F0;padding:4rpx 12rpx;border-radius:8rpx}
.item-status{font-size:24rpx;color:#999}
.item-status.Pending{color:#FAAD14}
.item-status.Resolved{color:#52C41A}
.item-content{font-size:28rpx;color:#333;display:block}
.item-reply{font-size:26rpx;color:#666;display:block;margin-top:12rpx;padding-top:12rpx;border-top:1rpx solid #eee}
