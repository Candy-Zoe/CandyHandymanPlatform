.container{padding:20rpx;background:#F5F5F5;min-height:100vh}
.header{padding:20rpx 0;margin-bottom:20rpx}
.title{font-size:36rpx;font-weight:bold;color:#333}
.list{display:flex;flex-direction:column;gap:16rpx}
.item{background:#fff;border-radius:12rpx;padding:24rpx}
.item-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:12rpx}
.item-title{font-size:30rpx;font-weight:bold;color:#333}
.item-type{font-size:22rpx;color:#FF6B35;background:#FFF5F0;padding:4rpx 12rpx;border-radius:8rpx}
.item-content{font-size:28rpx;color:#666;line-height:1.6;display:block}
.item-time{font-size:22rpx;color:#999;display:block;margin-top:12rpx}
.empty{display:flex;justify-content:center;align-items:center;height:400rpx;color:#999;font-size:30rpx}
