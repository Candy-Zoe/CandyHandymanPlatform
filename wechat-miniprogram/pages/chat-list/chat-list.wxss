.conv-item { display: flex; padding: 20rpx; background: white; margin-bottom: 2rpx; align-items: center; }
.conv-avatar-wrap { position: relative; margin-right: 20rpx; }
.conv-avatar { width: 96rpx; height: 96rpx; border-radius: 50%; }
.unread-badge { position: absolute; top: -4rpx; right: -4rpx; background: #FF6B35; color: white; font-size: 20rpx; min-width: 32rpx; height: 32rpx; border-radius: 16rpx; text-align: center; line-height: 32rpx; padding: 0 8rpx; }
.conv-info { flex: 1; }
.conv-name { font-size: 28rpx; font-weight: bold; display: block; margin-bottom: 8rpx; }
.conv-last-msg { font-size: 24rpx; color: #999; }